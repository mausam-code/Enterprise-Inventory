<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             mc:Ignorable="d" 
             x:Class ="EnterpriseInventory.WPF.Views.DashboardView"
             d:DesignHeight="125.503" d:DesignWidth="590.827">

    <Grid Background="#F5F5F5">
        <StackPanel 
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Margin="20">
            <TextBlock Text="Enterprise Inventory Dashboard"
                       FontSize="32"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>
            <TextBlock Text="Welcome to the ERP System"
                       FontSize="18"
                       HorizontalAlignment="Center"/>
            <UniformGrid Columns="3">
                <Border Margin="10" Padding="20" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Products" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding TotalProducts}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Margin="10" Padding="20" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Users" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding TotalUsers}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Margin="10" Padding="20" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Sales" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding TotalSales}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </Grid>
</UserControl>