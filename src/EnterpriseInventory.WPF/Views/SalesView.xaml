<UserControl x:Class="EnterpriseInventory.WPF.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
    <Grid>
        <TextBlock Text="Sales Page"
                   FontSize="30"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Grid>
    -->

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Sales Management" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        <Border Grid.Row="0" Background="#f8f9fa" Padding="20" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Add/View Sales" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="VendorName"/>
                        <TextBox Text="{Binding NewVendorName}" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="ContactPerson"/>
                        <TextBox Text="{Binding NewContactPerson}" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Balance"/>
                        <TextBox Text="{Binding NewBalance}" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                        <TextBlock Text="Phone"/>
                        <TextBox Text="{Binding NewPhone}" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="0,0,10,0">
                        <TextBlock Text="Email"/>
                        <TextBox Text="{Binding NewEmail}" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="5" Margin="0,0,10,0">
                        <TextBlock Text="Address"/>
                        <TextBox Text="{Binding NewAddress}" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                        <Button Content="Add" Command="{Binding AddSalesCommand}" 
                           Width="100" Height="30" Background="#28a745" Foreground="White"/>
                    </StackPanel>
                </Grid>

                <Button Content="Delete Selected" Command="{Binding DeleteSalesCommand}" 
                   Width="120" Height="35" Margin="0,15,0,0" Background="#dc3545" Foreground="White"
                   HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Sales}" SelectedItem="{Binding SelectedSales}"
             AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,0,0,20">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="VendorName" Binding="{Binding VendorName}" Width="*"/>
                <DataGridTextColumn Header="ContactPerson" Binding="{Binding ContactPerson}" Width="120"/>
                <DataGridTextColumn Header="Balance" Binding="{Binding Balance}" Width="120"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="100"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="100"/>
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>


    </Grid>

</UserControl>