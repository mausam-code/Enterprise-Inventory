<Window x:Class="EnterpriseInventory.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EnterpriseInventory.WPF.Views"
        Title="Enterprise Inventory"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#1E293B">

            <StackPanel Margin="20">

                <TextBlock Text="Enterprise ERP"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0 0 0 40"/>

                <Button Content="Dashboard"
                        Height="45"
                        Margin="0 0 0 10"
                        Command="{Binding ShowDashboardCommand}"/>

                <Button Content="Products"
                        Height="45"
                        Margin="0 0 0 10"
                        Command="{Binding ShowProductsCommand}"/>

                <Button Content="Sales"
                        Height="45"
                        Margin="0 0 0 10"
                        Command="{Binding ShowSalesCommand}"/>

                <Button Content="Reports"
                        Height="45"
                        Margin="0 0 0 10"
                        Command="{Binding ShowReportsCommand}"/>
                
                <Button Content="Add User"
                        Height="45"
                        Margin="0 0 0 10"
                        Command="{Binding ShowUserManagementCommand}"/>

                <Button Content="Logout"
                    Height="45"
                    Margin="0,40,0,0"
                    Command="{Binding LogoutCommand}"
                    Background="#DC3545"
                    Foreground="White"/>

            </StackPanel>

        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <!--
                <views:DashboardView/>
            -->
            <ContentControl Content="{Binding CurrentView}" />
            
        </Grid>

    </Grid>

</Window>